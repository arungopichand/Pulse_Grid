# Massive server-side market data key for primary live quotes and intraday aggregates.
MASSIVE_API_KEY=Xi6DL7iZ5sslV37hVivPC9zCd2NuyZA3

# Finnhub server-side market data key for live watchlist quote evaluation.
FINNHUB_API_KEY=
# Also powers structured news sentiment ingestion used by deterministic newsScore/BULLISH/BEARISH.
# Also powers provider-backed NEWS events in the live event tape.

# Twelve Data server-side market data key for fallback quotes and intraday volume/OHLCV endpoints.
# Add this in Vercel production before enabling any volume-based scanners.
TWELVE_DATA_API_KEY=

# Optional durable storage for session-aware live signal state across redeploys.
# Primary durable store is Supabase Storage.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=pulsegrid-state
SUPABASE_STORAGE_STATE_PREFIX=session-state

# Session state persistence controls.
DISABLE_STATE_PERSISTENCE=false
STATE_PERSIST_INTERVAL_MS=300000
STATE_STORE_KEY=live-session
ENABLE_LOCAL_STATE_FILE=false

# Optional one-off migration input for legacy Vercel Blob object URLs.
# Comma-separated list of direct JSON object URLs.
LEGACY_BLOB_URLS=

# Optional grounded LLM interpretation for scanner setups.
# If missing, the app uses deterministic rules-only analysis.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional model override for the in-app engineering support agent.
OPENAI_SUPPORT_AGENT_MODEL=gpt-5.5

# Live signal runtime controls (keep these conservative for paid market-data plans).
SIGNAL_SENSITIVITY=balanced
# Optional explicit overrides (defaults come from SIGNAL_SENSITIVITY presets).
# active: min move 0.8%, min RVOL 1.4x, cooldown 90s, max/cycle 3
# balanced: min move 1.5%, min RVOL 2.0x, cooldown 180s, max/cycle 2
# conservative: min move 2.5%, min RVOL 3.0x, cooldown 300s, max/cycle 2
SIGNAL_SCAN_INTERVAL_MS=2000
SIGNAL_IDLE_SCAN_INTERVAL_MS=5000
SIGNAL_ACTIVE_DEMAND_WINDOW_MS=60000
SIGNAL_MAX_SYMBOLS_PER_SCAN=50
SIGNAL_UNIVERSE_REFRESH_MS=60000
SIGNAL_NEWS_REFRESH_MS=90000
SIGNAL_MAX_API_CALLS_PER_MINUTE=90
SIGNAL_PER_SYMBOL_COOLDOWN_MS=180000
SIGNAL_STALE_TICK_THRESHOLD_MS=60000
SIGNAL_HALT_FREEZE_THRESHOLD_MS=75000
SIGNAL_ALLOW_EXTENDED_HOURS_HALT=false
SIGNAL_MOMENTUM_WINDOW_MS=180000
SIGNAL_VOLUME_BASELINE_WINDOW=8
SIGNAL_MIN_PRICE_MOVE_THRESHOLD=1.5
SIGNAL_MIN_VOLUME_RATIO_THRESHOLD=2
SIGNAL_MAX_SIGNALS_PER_CYCLE=2
